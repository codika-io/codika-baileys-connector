# =============================================================================
# Codika Baileys Connector - Configuration
# =============================================================================
# Copy this file to .env and fill in the required values.
#
# Quick start:
#   cp .env.example .env
#   # Edit the values below, then:
#   docker compose up -d
# =============================================================================

# -----------------------------------------------------------------------------
# REQUIRED: Your Codika webhook URL
# -----------------------------------------------------------------------------
# This is the URL where WhatsApp messages will be forwarded.
# You received this URL from your Codika dashboard or support team.
WEBHOOK_URL=https://REPLACE_WITH_YOUR_WEBHOOK_URL

# -----------------------------------------------------------------------------
# REQUIRED: API Key
# -----------------------------------------------------------------------------
# Protects the Evolution API endpoints. Generate a strong random key:
#   openssl rand -hex 32
EVOLUTION_API_KEY=CHANGE_ME_TO_A_STRONG_RANDOM_KEY

# -----------------------------------------------------------------------------
# REQUIRED: Database password
# -----------------------------------------------------------------------------
# Choose a strong password for the internal PostgreSQL database.
POSTGRES_PASSWORD=CHANGE_ME_TO_A_STRONG_PASSWORD

# -----------------------------------------------------------------------------
# Server URL (set this in production)
# -----------------------------------------------------------------------------
# The public URL of this server. Required for webhook callbacks.
# Example: https://connector.yourdomain.com
# If using a VPS with just an IP: http://YOUR_VPS_IP:8080
EVOLUTION_SERVER_URL=http://localhost:8080

# -----------------------------------------------------------------------------
# Optional settings (defaults are fine for most setups)
# -----------------------------------------------------------------------------

# Docker image version
EVOLUTION_API_VERSION=v2.3.7

# Port to expose (default: 8080)
EVOLUTION_API_PORT=8080

# Database name and user (no need to change)
POSTGRES_DB=evolution_db
POSTGRES_USER=evolution

# Device name shown on the phone's linked devices list
SESSION_PHONE_CLIENT=Community Bot

# Auto-delete disconnected instances (false = keep forever)
DEL_INSTANCE=false

# Enable/disable webhook forwarding (true by default)
WEBHOOK_ENABLED=true
